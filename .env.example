# TikHub API token
TIKHUB_API_KEY=

# Optional base URL override
TIKHUB_BASE_URL=https://api.tikhub.io
# Optional fallback base URL (for region-specific networking issues)
TIKHUB_FALLBACK_BASE_URL=https://api.tikhub.dev

# Runtime controls
TIKHUB_TIMEOUT_MS=30000
TIKHUB_MAX_RETRIES=3
TIKHUB_GLOBAL_QPS=10
TIKHUB_MAX_IN_FLIGHT=5
